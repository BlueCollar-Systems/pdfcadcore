# Normalize line endings: store text as LF in the repo AND in the working tree.
# CRLF/LF churn previously made pdfcadcore_sync_check.py report false "drift"
# between this LF canonical and the importers' CRLF checkouts. Keep canonical LF.
* text=auto eol=lf

*.py   text eol=lf
*.md   text eol=lf
*.txt  text eol=lf
*.json text eol=lf
*.cfg  text eol=lf
*.toml text eol=lf

# Binary assets — never normalize
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.pdf binary
*.zip binary
*.skp binary
